{
  "expo": {
    "name": "Imaniq",
    "slug": "imaniq",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "imaniq",
    "description": "Imaniq — Dein islamischer Begleiter",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1628"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.imaniq.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Wird für die Berechnung der Gebetszeiten und Qibla-Richtung benötigt.",
        "NSMotionUsageDescription": "Wird für den Qibla-Kompass benötigt."
      }
    },
    "android": {
      "package": "com.imaniq.app",
      "adaptiveIcon": {
        "backgroundColor": "#0A1628"
      },
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION", "VIBRATE"]
    },
    "plugins": ["expo-router", "expo-location", "expo-sensors", "expo-notifications"],
    "experiments": { "typedRoutes": true }
  }
}
